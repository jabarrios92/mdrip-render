{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback and ratings",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the customer"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the customer (optional)"
        },
        "message": {
          "type": "string",
          "description": "The feedback message"
        },
        "rating": {
          "type": "integer",
          "description": "Rating from 1 to 5"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the feedback was submitted"
        }
      },
      "required": ["name", "message", "rating", "createdAt"]
    }
  },
  "firestore": {
    "feedback": {
      "schema": "Feedback",
      "description": "Collection of customer feedback"
    }
  }
}
